# Copy to .env on the production server: /srv/IPSA/Website/.env
# Then rebuild: docker compose up -d --build

# Google Analytics 4 — Measurement ID (format: G-XXXXXXXXXX)
GA_MEASUREMENT_ID=

# Google Search Console — HTML meta tag verification code
GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools — HTML meta tag verification code
BING_SITE_VERIFICATION=

# Resend — Email service for contact form (https://resend.com)
# Get API key: Resend Dashboard → API Keys → Create
RESEND_API_KEY=

# Contact form recipient email
CONTACT_EMAIL=ventas.mexico@ipsa-cv.com.mx

# Sender address (after domain verification: "IPSA Web <contacto@ipsacv.com.mx>")
RESEND_FROM=IPSA Web <onboarding@resend.dev>
